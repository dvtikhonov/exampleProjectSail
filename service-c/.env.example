APP_NAME=service-c
APP_ENV=local
APP_KEY=base64:s2bxw851yyJIXAFqldUPtJppq7nZLu0fro4YfyTxPe0=
APP_DEBUG=true
APP_URL=http://localhost:8083
# Production VPS (тот же домен, что main-app):
# APP_URL=https://94-228-117-27.sslip.io
# MAX_WEBHOOK_URL=https://94-228-117-27.sslip.io/api/webhooks/max
# Кабинет MAX → URL мини-приложения: https://94-228-117-27.sslip.io/max-app
#
# VPS hybrid (локальный service-c + SSH tunnel, отдельный dev-домен):
# cp scripts/vps-tunnel.env.example scripts/vps-tunnel.env
# APP_URL=https://max-dev.94-228-117-27.sslip.io
# MAX_WEBHOOK_URL=https://max-dev.94-228-117-27.sslip.io/api/webhooks/max
# MAX_MINI_APP_URL можно не задавать — выводится из MAX_WEBHOOK_URL (+ /max-app)
# MAX_BOT_USER_ID — user_id бота из max:bot:info (contact_id для open_app).

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single,messMax
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
# Общая БД с main-app; таблицы (users и др.) создаются миграциями main-app
DB_DATABASE=sail_db
DB_USERNAME=root
DB_PASSWORD=12345678AS

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# MAX messenger / mini-app
# Локальная отладка в браузере: http://localhost:8083/max-app
# MAX_LOCAL_DEV_USER_ID — демо-пользователь (1001–1004, см. config/max.php → local_dev_demo_users).
MAX_LOCAL_DEV_INIT_DATA=false
MAX_LOCAL_DEV_USER_ID=1002
MAX_BOT_ACCESS_TOKEN=
MAX_BOT_USERNAME=
MAX_BOT_USER_ID=
MAX_WEBHOOK_URL=
MAX_WEBHOOK_SECRET=
MAX_MINI_APP_URL=
MAX_UI_STAND_MINI_APP_BUTTON_TEXT="Заказ еды"
MAX_MINIAPP_AUTH_DATE_MAX_AGE_SECONDS=86400
MAX_MINIAPP_TOKEN_TTL_SECONDS=86400
MAX_UI_STAND_GREETING="Привет! Выберите ответ:"
MAX_UI_STAND_CHAT_IDS=
MAX_UI_STAND_USER_IDS=

# Уведомления о заказах в MAX-чаты отчётов (те же ID, что в service-b)
MAX_REPORT_CHAT_IDS=
MAX_REPORT_USER_IDS=

VITE_APP_NAME="${APP_NAME}"
