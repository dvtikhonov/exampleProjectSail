MAIN_APP_PORT=8000
SERVICE_A_PORT=8081
SERVICE_B_PORT=8082

MYSQL_PORT=3306     # порт на хосте (можно оставить 3306, если не занят)
REDIS_PORT=6379
MAILHOG_PORT=8025

# Xdebug: у вас nameserver в resolv.conf (172.27.0.1) — это нормально для WSL2, это адрес Windows на vEthernet.
# Проблема «нет останова» почти всегда в том, что PHPStorm слушает только 127.0.0.1 на Windows, а контейнер шлёт на 172.27.0.1.
# 1) PHPStorm: Settings → PHP → Debug → включить «Can accept external connections» + Start Listening.
# 2) В PowerShell (админ): netstat -an | findstr 9003 — должно быть 0.0.0.0:9003, не только 127.0.0.1:9003.
# 3) Если только 127.0.0.1 — один раз (админ PowerShell), проброс на IDE (IP как у вас в resolv, иначе возьмите IPv4 из ipconfig → vEthernet WSL):
#    netsh interface portproxy add v4tov4 listenaddress=172.27.0.1 listenport=9003 connectaddress=127.0.0.1 connectport=9003
#    Снять: netsh interface portproxy delete v4tov4 listenaddress=172.27.0.1 listenport=9003
XDEBUG_CLIENT_HOST=172.27.0.1
XDEBUG_CLIENT_PORT=9003
